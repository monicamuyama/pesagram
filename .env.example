# Environment Configuration
NODE_ENV=development
PORT=3000

# MongoDB Atlas Configuration
MONGODB_URI=
DB_NAME=

# Bitnob Sandbox API Configuration
BITNOB_BASE_URL=
BITNOB_API_KEY=

# JWT Configuration (Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=
JWT_EXPIRES_IN=24h

# CORS Configuration
# Development: Include localhost and your computer's IP for mobile testing
# Production: Replace with your actual deployed URLs
ALLOWED_ORIGINS=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_ROUNDS=12
