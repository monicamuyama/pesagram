# Environment Configuration
NODE_ENV=development
PORT=3000

# MongoDB Atlas Configuration
MONGODB_URI=
DB_NAME=

# Bitnob Sandbox API Configuration
BITNOB_BASE_URL=https://sandboxapi.bitnob.co
BITNOB_API_KEY=

# JWT Configuration (Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=GENERATE_YOUR_OWN_SECURE_RANDOM_64_BYTE_HEX_STRING_HERE
JWT_EXPIRES_IN=24h

# CORS Configuration
# Development: Include localhost and your computer's IP for mobile testing
# Production: Replace with your actual deployed URLs
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://YOUR_COMPUTER_IP:3000,https://your-frontend-domain.vercel.app,capacitor://localhost,http://localhost,ionic://localhost

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_ROUNDS=12
