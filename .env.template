# ========================================
# Pesagram Backend Environment Configuration
# ========================================

# Application Settings
NODE_ENV=development
PORT=3000
APP_NAME=Pesagram
APP_VERSION=1.0.0

# ========================================
# Database Configuration
# ========================================

# PostgreSQL (Recommended for Production)
# DATABASE_URL=postgresql://username:password@localhost:5432/pesagram_db
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pesagram_db
# DB_USER=your_db_username
# DB_PASSWORD=your_db_password

# SQLite (Good for Development)
DATABASE_URL=sqlite:./pesagram.db

# ========================================
# Bitnob API Configuration
# ========================================

# Sandbox Configuration (for testing)
BITNOB_BASE_URL=https://sandboxapi.bitnob.co/api
BITNOB_API_KEY=sk.3a846ff0dfb8.7e7ddae08f05636a83433470b
BITNOB_ENVIRONMENT=sandbox

# Production Configuration (uncomment when going live)
# BITNOB_BASE_URL=https://api.bitnob.co/api
# BITNOB_API_KEY=your_production_api_key
# BITNOB_ENVIRONMENT=production

# Webhook Configuration
BITNOB_WEBHOOK_SECRET=your_webhook_secret_here_generate_random_string
BITNOB_WEBHOOK_URL=https://yourdomain.com/api/webhooks/bitnob

# ========================================
# Authentication & Security
# ========================================

# JWT Configuration
JWT_SECRET=pesagram_super_secure_jwt_secret_key_2024_CHANGE_IN_PRODUCTION_MINIMUM_32_CHARS
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=12

# Session Configuration
SESSION_SECRET=your_session_secret_here_minimum_32_chars

# ========================================
# Email Configuration
# ========================================

# SMTP Settings (for email verification, password reset, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Email From Address
EMAIL_FROM=noreply@pesagram.com
EMAIL_FROM_NAME=Pesagram Team

# ========================================
# Push Notifications
# ========================================

# Firebase Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key_here
FCM_PROJECT_ID=your_firebase_project_id

# ========================================
# CORS & Security
# ========================================

# Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://yourdomain.com

# Security Headers
SECURITY_HEADERS_ENABLED=true

# ========================================
# Rate Limiting
# ========================================

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# API Rate Limiting
API_RATE_LIMIT_WINDOW_MS=300000
API_RATE_LIMIT_MAX_REQUESTS=50

# Auth Rate Limiting (stricter for auth endpoints)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# ========================================
# File Storage
# ========================================

# Local Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# AWS S3 (for production file storage)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=pesagram-uploads

# ========================================
# Logging
# ========================================

# Log Level (error, warn, info, debug)
LOG_LEVEL=debug

# Log File Path
LOG_FILE=./logs/app.log

# ========================================
# Monitoring & Analytics
# ========================================

# Sentry (Error Tracking)
# SENTRY_DSN=your_sentry_dsn_here

# Google Analytics
# GA_TRACKING_ID=UA-XXXXXXXXX-X

# ========================================
# External APIs
# ========================================

# Exchange Rate APIs (for currency conversion)
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key

# SMS Provider (for phone verification)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ========================================
# Development/Testing
# ========================================

# Test Database
TEST_DATABASE_URL=sqlite::memory:

# Test API Keys
TEST_BITNOB_API_KEY=test_key_here

# Mock Services
MOCK_BITNOB_API=false
MOCK_EMAIL_SERVICE=true
MOCK_SMS_SERVICE=true

# ========================================
# Production Settings
# ========================================

# SSL/TLS
SSL_ENABLED=false
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# Cluster Mode
CLUSTER_MODE=false
CLUSTER_WORKERS=4

# Health Check
HEALTH_CHECK_INTERVAL=30000

# ========================================
# Cache Configuration
# ========================================

# Redis (for caching and sessions)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# Cache TTL (seconds)
CACHE_TTL=3600

# ========================================
# Documentation
# ========================================

# API Documentation
API_DOCS_ENABLED=true
API_DOCS_URL=/api/docs
